# CoDD プロジェクト設定
version: "0.1.0"
codd_required_version: null
codd_required_version_strict: false

project:
  name: "{{project_name}}"
  language: "{{language}}"
  frameworks: []

ai_command: "claude --print --permission-mode bypassPermissions --dangerously-skip-permissions --model claude-opus-4-8 --effort max --tools \"\""

