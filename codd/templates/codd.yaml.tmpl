# CoDD プロジェクト設定
version: "0.1.0"
codd_required_version: null
codd_required_version_strict: false

project:
  name: "{{project_name}}"
  language: "{{language}}"
  frameworks: []

ai_command: "claude --print --model claude-opus-4-6 --tools \"\""
coding_principles: null

# operation_flow (optional - declare UI topology per operation):
# operation_flow:
#   operations:
#     - id: "example_action"
#       actor: "role_name"
#       verb: "manage_collection"
#       target: "child_entity"
#       parent: "parent_entity"
#       ui_pattern: "master_detail"
#
# ui_coherence:
#   ignore_relations:
#     - {parent: "foo", child: "bar"}  # intentional single-screen design

scan:
  source_dirs:
{{source_dirs}}
  test_dirs:
    - "tests/"
  doc_dirs:
    - "docs/"
  config_files: []
  exclude:
    - "**/node_modules/**"
    - "**/__pycache__/**"
    - "**/dist/**"

graph:
  store: "jsonl"
  path: "{{graph_path}}"

bands:
  green:
    min_confidence: 0.90
    min_evidence_count: 2
  amber:
    min_confidence: 0.50

propagation:
  max_depth: 10
  stop_at_contract_boundary: true

typecheck:
  enabled: false
  command: null
  max_repair_attempts: 3

# verify:
#   verification_timeout:
#     per_node_seconds: 60    # optional: hard cap for each verification_test node
#     total_seconds: 300      # optional: total budget for all verification_test nodes

ci:
  provider: github_actions   # github_actions | gitlab_ci | none
  workflow_glob: .github/workflows/*.yml
  required_triggers:
    - push
    - pull_request
  runtime_check: false       # opt-in (v2.13.0)
  staleness_days: 14
  default_branch: main

context_acquisition:
  enabled: true
  strategy: web_search_first   # web_search_first | offline | human_only
  sources:
    - type: official_docs
      priority: high
    - type: github_search
      priority: medium
    - type: web_search
      priority: medium
  cache_ttl_days: 30
  freshness_check_on_startup: false
  fact_check:
    enabled: true
    min_sources: 2
    min_confidence: 0.6

